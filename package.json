{
  "name": "html-demo-material-editor",
  "version": "0.1.3",
  "description": "Windows-ready HTML presentation editor for AI-generated demo materials.",
  "license": "MIT",
  "author": "Maxwillbebetter",
  "homepage": "https://github.com/Maxwillbebetter/html-demo-editor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maxwillbebetter/html-demo-editor.git"
  },
  "bugs": {
    "url": "https://github.com/Maxwillbebetter/html-demo-editor/issues"
  },
  "keywords": [
    "electron",
    "presentation",
    "html-editor",
    "slides",
    "grapesjs"
  ],
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:assets": "node scripts/asset-copy-smoke.mjs",
    "test:smoke": "node scripts/smoke-rendering.mjs",
    "test:ui": "node scripts/ui-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac:dmg": "npm run build && electron-builder --mac dmg --publish never",
    "dist:mac:zip": "npm run build && electron-builder --mac zip --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:win:installer": "npm run build && electron-builder --win nsis --publish never",
    "dist:win:portable": "npm run build && electron-builder --win portable --publish never"
  },
  "build": {
    "appId": "cn.local.htmldemo.editor",
    "productName": "HTML Demo Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": [
          "html",
          "htm"
        ],
        "name": "HTML Demo Material",
        "description": "HTML presentation material",
        "role": "Editor"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "HTML-Demo-Editor-${version}-Mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "HTML-Demo-Editor-${version}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "HTML-Demo-Editor-${version}-Portable.${ext}"
    }
  },
  "dependencies": {
    "grapesjs": "^0.22.13",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-preset-webpage": "^1.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
